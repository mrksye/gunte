{
  "name": "goonteh",
  "version": "1.0.0",
  "description": "Tiny pointer-based drag-and-drop that works on touch and never shows the no-drop cursor. Framework-agnostic core plus SolidJS, React, Vue, Svelte, native DOM, and React Native adapters.",
  "type": "module",
  "license": "MIT",
  "author": "mrksye",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrksye/goonteh.git"
  },
  "bugs": {
    "url": "https://github.com/mrksye/goonteh/issues"
  },
  "homepage": "https://github.com/mrksye/goonteh#readme",
  "keywords": [
    "drag-and-drop",
    "dnd",
    "pointer-events",
    "touch",
    "mobile",
    "solid-js",
    "solidjs",
    "react",
    "react-native",
    "vue",
    "svelte"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "build": "rm -rf dist && node build.mjs && tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.28.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "solid-js": "^1.8.0",
    "svelte": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.4",
    "vue": "^3.4.0"
  },
  "files": [
    "dist",
    "core.ts",
    "native.ts",
    "solid.tsx",
    "react.tsx",
    "react-native.tsx",
    "vue.ts",
    "svelte.ts",
    "index.ts",
    "README.md",
    "EXAMPLES.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "main": "./dist/core.js",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "unpkg": "./dist/goonteh.global.js",
  "jsdelivr": "./dist/goonteh.global.js",
  "exports": {
    ".": { "types": "./dist/core.d.ts", "import": "./dist/core.js" },
    "./core": { "types": "./dist/core.d.ts", "import": "./dist/core.js" },
    "./native": { "types": "./dist/native.d.ts", "import": "./dist/native.js" },
    "./global": "./dist/goonteh.global.js",
    "./solid": "./solid.tsx",
    "./react": "./react.tsx",
    "./react-native": "./react-native.tsx",
    "./vue": "./vue.ts",
    "./svelte": "./svelte.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-native": ">=0.70.0",
    "solid-js": ">=1.6.0",
    "svelte": ">=4.0.0",
    "vue": ">=3.2.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  }
}
